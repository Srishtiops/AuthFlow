{
  "name": "ins",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i ./frontend/styles/tailwind.css -o ./static/css/theme.css --minify",
    "build:js": "npx esbuild ./frontend/react/theme-widget.jsx --bundle --minify --outfile=./static/js/theme-react.js --format=iife --platform=browser",
    "build": "npm run build:css && npm run build:js",
    "watch:css": "npx @tailwindcss/cli -i ./frontend/styles/tailwind.css -o ./static/css/theme.css --watch=always",
    "watch:js": "npx esbuild ./frontend/react/theme-widget.jsx --bundle --outfile=./static/js/theme-react.js --format=iife --platform=browser --watch=forever",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
